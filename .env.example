# --- Slack (Socket Mode) ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# --- LLM (litellm library; local ollama by default, flip model string for paid) ---
LLM_MODEL=ollama/qwen3:14b          # or anthropic/claude-sonnet-5, openai/gpt-...
EMBED_MODEL=ollama/nomic-embed-text # 768-dim; re-embed everything if you change this
EMBED_DIM=768
OLLAMA_API_BASE=http://localhost:11434

# --- Data ---
DATABASE_URL=postgresql+asyncpg://slackagent:slackagent@localhost:5432/slackagent
REDIS_URL=redis://localhost:6379/0

# --- Integrations (remote MCP servers, streamable HTTP) ---
JIRA_MCP_URL=
NOTION_MCP_URL=
JIRA_PROJECT_KEY=
NOTION_DATA_SOURCE_ID=

# --- Observability (optional; enables litellm->langfuse callback if set) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# --- Guardrails ---
GRAPH_RECURSION_LIMIT=12
TOKEN_BUCKET_PER_USER=50000
TOKEN_BUCKET_PER_CHANNEL=200000

# --- Standup ---
STANDUP_CHANNEL=
STANDUP_CRON=0 9 * * mon-fri
STANDUP_COLLECT_MINUTES=60

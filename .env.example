# --- GitHub ---
GITHUB_WEBHOOK_SECRET=changeme
GITHUB_TOKEN=github_pat_...        # fine-grained: contents+pull_requests+issues write, target repos only
TARGET_REPOS=you/demo-repo         # comma-separated owner/name
TRIGGER_LABEL=swarm-fix

# --- Telegram ---
TELEGRAM_BOT_TOKEN=...             # from @BotFather
TELEGRAM_CHAT_ID=...               # your personal chat id; only this id may approve

# --- LLM routing (litellm; develop on Ollama, flip to Anthropic for demo day) ---
# Defaults sized for a 16–24GB machine. Run `uv run python -m scripts.recommend_models` for yours.
#   32GB Mac / 24GB+ VRAM : PROPOSER_MODEL=ollama/qwen3-coder:30b
#   16–24GB               : ollama/qwen2.5-coder:14b (below)
PROPOSER_MODEL=ollama/qwen2.5-coder:14b     # demo: anthropic/claude-sonnet-4-6
BREAKER_MODEL=ollama/qwen3:14b              # demo: anthropic/claude-haiku-4-5
ARBITRATOR_MODEL=ollama/qwen3:14b           # demo: anthropic/claude-haiku-4-5
EMBED_MODEL=ollama/nomic-embed-text         # 768-dim; re-embed everything if changed
EMBED_DIM=768
OLLAMA_API_BASE=http://localhost:11434
ANTHROPIC_API_KEY=                 # the £4.90 — guarded by DAILY_SPEND_CAP_USD

# Per-agent RAG context size. Haiku (breaker/arbitrator) needs a >=4096-token cached prefix or
# Anthropic silently skips prompt caching, so those two retrieve more chunks. Sonnet's min is 1024.
PROPOSER_CONTEXT_CHUNKS=8
BREAKER_CONTEXT_CHUNKS=12
ARBITRATOR_CONTEXT_CHUNKS=12

# --- Data ---
DATABASE_URL=postgresql+asyncpg://swarm:swarm@localhost:5432/swarm
REDIS_URL=redis://localhost:6379/0
REPOS_DIR=./repos                  # local clones of target repos

# --- Guardrails ---
GRAPH_RECURSION_LIMIT=40           # counts every supervisor hop; ~25 needed for 2 revise rounds
MAX_REVISION_ROUNDS=2
TOKEN_BUCKET_PER_RUN=250000
DAILY_SPEND_CAP_USD=1.50

# --- Sandbox ---
SANDBOX_IMAGE=swarm-sandbox
SANDBOX_TIMEOUT_S=180
SANDBOX_MEMORY_MB=1024

# --- Observability (optional; litellm->langfuse callback when set) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
